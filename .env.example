# Socrata app token — get one free at https://data.cdc.gov/profile/edit/developer_settings
# Without this, requests share a throttled IP pool and may get 429 errors under load.
CDC_APP_TOKEN=your_app_token_here

# Maximum rows returned per cdc_query_dataset call (hard server-side cap)
CDC_MAX_ROWS=500

# Default rows returned when the agent doesn't specify a limit
CDC_DEFAULT_ROWS=50

# Request timeout in seconds for Socrata API calls
CDC_TIMEOUT_SECONDS=30
